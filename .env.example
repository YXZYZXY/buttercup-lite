API_PORT=8000
REDIS_URL=redis://redis:6379/0
DATA_ROOT=/data/tasks
QUEUE_BLOCK_TIMEOUT=2
SCHEDULER_READY_HOLD_SECONDS=0
LLM_ENABLED=true
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=your_deepseek_api_key_here
LLM_MODEL=deepseek-chat
LLM_TIMEOUT_SECONDS=300
LLM_MAX_RETRIES=4
LLM_TEMPERATURE=0.35
LLM_MAX_TOKENS=0
# blind mode keeps ground truth out of candidate ranking and is recommended for generalization runs.
# benchmark_assisted allows GT-informed ranking for internal comparison/debugging only.
PATCH_GROUND_TRUTH_MODE=blind
SEED_FUNCTION_TIMEOUT_SECONDS=20
SEED_MAX_BYTES=262144
SEED_IMPORT_SAMPLE_LIMIT=64
SEED_GENERATION_ATTEMPTS=6
BUILD_TIMEOUT_SECONDS=1200
FUZZ_MAX_TOTAL_TIME_SECONDS=180
FUZZ_TIMEOUT_SECONDS=10
# fork mode lets libFuzzer keep running after crashes and is recommended.
FUZZ_FORK_MODE=true
FUZZ_FORK_JOBS=1
FUZZ_IGNORE_CRASHES=true
# Per-process memory limit in fork mode (MB).
FUZZ_RSS_LIMIT_MB=2048
# Limit how many crashes flow into trace after fuzzing in fork mode.
FUZZ_MAX_CRASHES_TO_TRACE=50
# Minimum rounds between coverage-guided campaign reseeding attempts.
CAMPAIGN_RESEED_COOLDOWN_ROUNDS=3
# Campaign manifests use cumulative crash totals and deduplicated PoV/signature counts:
# `total_raw_crash_count`, `total_traced_crash_count`, `distinct_pov_count`, `distinct_signature_count`.
# Character budget for multi-hop context expansion around the selected target.
CONTEXT_HOP_BUDGET_CHARS=6000
# Additional hops to expand beyond direct callers/callees.
CONTEXT_MAX_HOPS=2
# Keywords that prioritize deeper expansion candidates.
CONTEXT_HOP_KEYWORDS=parse,read,alloc,free,len,size,bound,check
FUZZ_MAX_LEN=262144
# Set to true to stop libFuzzer at the first crash. Not recommended because it distorts coverage.
FUZZ_ABORT_ON_ERROR=false
FUZZ_SEED_FROM_IMPORTED_VALID_CRASHES=true
FUZZ_IMPORTED_VALID_SEED_LIMIT=4
ALLOW_IMPORTED_CRASH_FALLBACK=false
ALLOW_HARNESS_SWITCH=false
CRASH_SOURCE_POLICY=live_raw_only
REPLAY_TIMEOUT_SECONDS=60
REPRO_ATTEMPTS=5
BINARY_DEFAULT_BACKEND=auto
BUILD_TOOLCHAIN_PREFIX=/home/buttercup2/Project/buttercup-lite/.toolchains/build-env
BINARY_WRAPPER_TIMEOUT_SECONDS=300
IDA_MCP_COMMAND=
IDA_MCP_TIMEOUT_SECONDS=1200
BINARY_STRINGS_LIMIT=20000
BINARY_FUNCTIONS_LIMIT=20000
HOST_HOME=/home/buttercup2
PROTO_BACKEND_ROOT=/opt/proto-backend
PROTO_BACKEND_ROOT_HOST=/home/buttercup2/protocol_seed/proto-fuzz-3dockers
PROTO_BACKEND_TASK_JSON_NAME=protocol/task.json
